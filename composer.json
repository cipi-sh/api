{
    "name": "andreapollastri/cipi-api",
    "description": "Cipi API — REST API, MCP server, and Swagger docs for the Cipi server control panel",
    "keywords": ["cipi", "laravel", "api", "mcp", "server", "deploy"],
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^12.0",
        "laravel/sanctum": "^4.0",
        "laravel/mcp": "^0.1"
    },
    "autoload": {
        "psr-4": {
            "CipiApi\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "CipiApi\\CipiApiServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
